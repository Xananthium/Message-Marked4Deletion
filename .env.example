# Agent-in-a-Box — copy to .env and populate before enabling aib-poller.service
AIB_DSN=postgresql:///agentinabox
AIB_SA_PATH=/home/discnxt/.secrets/google-agents.json
AIB_MAILBOX=team@digitaldisconnections.com
AIB_OPERATOR_EMAIL=cass@digitaldisconnections.com
AIB_SSH_ALIAS=contabo
AIB_MODEL=ollama_chat/kimi-k2.6:cloud
AIB_TMP_ROOT=/tmp/aib
# Namecheap API — used by provision-site.sh
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
NAMECHEAP_USERNAME=
NAMECHEAP_CLIENT_IP=
CONTABO_IP=
